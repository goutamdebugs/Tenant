{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras", 
  "controllerPathGlobs": [
    "src/controllers/**/*.ts"
  ],
  "routes": {
    "routesDir": "src/routes"
  },
  "spec": {
    "outputDirectory": "src/swagger",
    "specVersion": 3,
    "basePath": "/api",
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}